CREATE TABLE IF NOT EXISTS Rate (
  `id` INTEGER PRIMARY KEY AUTOINCREMENT NOT NULL,
  `date` TEXT NOT NULL,
  `bankId` INTEGER NOT NULL,
  `currencyId` INTEGER NOT NULL,
  `buyRate` REAL NOT NULL,
  `sellRate` REAL NOT NULL
 );

 CREATE INDEX IF NOT EXISTS `index_rates_buy` ON `Rate` (`buyRate`);
 CREATE INDEX IF NOT EXISTS `index_rates_sell` ON `Rate` (`sellRate`);

loadAllRates:
SELECT * FROM Rate;

loadOldRates:
SELECT id FROM Rate WHERE date(date) < date('now');

loadBestBuyRates:
SELECT Bank.formattedName AS bankName, max(Rate.buyRate), Currency.name, Rate.currencyId FROM Rate
JOIN Bank ON Rate.bankId = Bank.id
JOIN Currency ON Rate.currencyId = Currency.id
WHERE Rate.currencyId IN :currencyIds AND datetime(Rate.date) >= datetime('now');

loadBestSellRates:
SELECT Bank.formattedName AS bankName, min(Rate.sellRate), Currency.name, Rate.currencyId FROM Rate
JOIN Bank ON Rate.bankId = Bank.id
JOIN Currency ON Rate.currencyId = Currency.id
WHERE Rate.currencyId IN :currencyIds AND datetime(Rate.date) >= datetime('now');

insertRate:
INSERT OR REPLACE INTO Rate(id, date, bankId, currencyId, buyRate, sellRate)
VALUES ?;
